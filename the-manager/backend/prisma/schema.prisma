// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "darwin", "darwin-arm64"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String?  @unique
  password  String
  name      String
  avatar    String?
  role      String   @default("MANAGER")
  
  preferences String?  // stored as JSON text
  
  hasPassword Boolean @default(true)
  notesPasswordHash String?
  resetToken    String?
  resetTokenExpiry DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lastLogin DateTime?

  // Relations
  initiatives Initiative[] @relation("InitiativeCreator")
  assignedInitiatives Initiative[] @relation("InitiativeAssignees")
  comments Comment[]
  activityLogs ActivityLog[]
  links Link[]
  canvases Canvas[]
  brainstormCanvas BrainstormCanvas?
  notes Note[]
  meetingNotes MeetingNote[]
  googleToken GoogleToken?

  @@map("users")
}

model Initiative {
  id          String   @id @default(uuid())
  title       String
  description String?
  type        String @default("INITIATIVE")
  
  // Hierarchy
  parentId    String?
  parent      Initiative? @relation("InitiativeChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children    Initiative[] @relation("InitiativeChildren")
  
  // Status & Priority
  status      String   @default("OPEN")
  priority    String   @default("MEDIUM")
  
  // Dates & Progress
  startDate   DateTime?
  dueDate     DateTime?
  completedAt DateTime?
  progress    Int      @default(0) // 0-100
  
  // Tags & Metadata
  tags        String   @default("[]")

  // Standalone task flag & optional initiative link
  isStandaloneTask    Boolean  @default(false)
  linkedInitiativeId  String?
  linkedInitiative    Initiative? @relation("TaskInitiativeLink", fields: [linkedInitiativeId], references: [id], onDelete: SetNull)
  linkedTasks         Initiative[] @relation("TaskInitiativeLink")

  // External integrations (JIRA tickets, Confluence pages, etc.)
  integrationItems IntegrationItem[]

  // Canvas
  canvasId    String?
  canvas      Canvas?  @relation(fields: [canvasId], references: [id])
  
  // Position for mind map view
  positionX   Float?
  positionY   Float?
  
  // Relations
  createdById String
  createdBy   User     @relation("InitiativeCreator", fields: [createdById], references: [id])
  
  assignees   User[]   @relation("InitiativeAssignees")
  
  links       Link[]
  comments    Comment[]
  activityLogs ActivityLog[]
  meetingNotes MeetingNote[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([parentId])
  @@index([status])
  @@index([priority])
  @@index([createdById])
  @@index([canvasId])
  @@map("initiatives")
}

model Link {
  id            String   @id @default(uuid())
  url           String
  title         String?
  description   String?
  category      String?
  tags          String   @default("[]")
  
  initiativeId  String
  initiative    Initiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  
  createdById   String
  createdBy     User     @relation(fields: [createdById], references: [id])
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([initiativeId])
  @@map("links")
}

model Comment {
  id            String   @id @default(uuid())
  content       String
  
  initiativeId  String
  initiative    Initiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([initiativeId])
  @@map("comments")
}

model ActivityLog {
  id            String   @id @default(uuid())
  action        String
  changes       String?  // stored as JSON text
  
  initiativeId  String
  initiative    Initiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  
  timestamp     DateTime @default(now())

  @@index([initiativeId])
  @@index([timestamp])
  @@map("activity_logs")
}

// Note: enums are emulated as String fields for SQLite compatibility.
// Valid Role values:          ADMIN | MANAGER | VIEWER
// Valid InitiativeType values: INITIATIVE | TASK | SUBTASK
// Valid Status values:        OPEN | IN_PROGRESS | BLOCKED | ON_HOLD | COMPLETED | CANCELLED
// Valid Priority values:      CRITICAL | HIGH | MEDIUM | LOW

model Canvas {
  id          String   @id @default(uuid())
  name        String
  description String?
  color       String   @default("#6366f1")

  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])

  initiatives Initiative[]
  notes       Note[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([createdById])
  @@map("canvases")
}

model BrainstormCanvas {
  id        String   @id @default(uuid())
  nodes     String   @default("[]")
  edges     String   @default("[]")

  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("brainstorm_canvases")
}

model Note {
  id           String   @id @default(uuid())
  title        String
  content      String   @default("")
  isProtected  Boolean  @default(false)
  passwordHash String?

  // Hierarchy — unlimited nesting depth
  parentId     String?
  parent       Note?    @relation("NoteChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children     Note[]   @relation("NoteChildren")

  canvasId     String?
  canvas       Canvas?  @relation(fields: [canvasId], references: [id], onDelete: SetNull)

  createdById  String
  createdBy    User     @relation(fields: [createdById], references: [id])

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([createdById])
  @@index([canvasId])
  @@index([parentId])
  @@map("notes")
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

model IntegrationItem {
  id           String   @id @default(uuid())
  type         String   // JIRA | CONFLUENCE
  key          String?  // JIRA: ticket key (e.g. PROJ-123); Confluence: page ID
  url          String
  title        String?
  cachedData   String?  // JSON snapshot from API

  initiativeId String
  initiative   Initiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([initiativeId])
  @@map("integration_items")
}

model GoogleToken {
  userId       String   @id
  accessToken  String
  refreshToken String?
  expiryDate   String?
  scope        String?
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("google_tokens")
}

model MeetingNote {
  id          String   @id @default(uuid())
  subject     String
  fromEmail   String?
  date        DateTime?
  body        String   @default("")

  initiativeId String?
  initiative   Initiative? @relation(fields: [initiativeId], references: [id], onDelete: SetNull)

  createdById  String
  createdBy    User     @relation(fields: [createdById], references: [id])

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([initiativeId])
  @@index([createdById])
  @@map("meeting_notes")
}
